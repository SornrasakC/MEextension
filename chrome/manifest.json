{
    "manifest_version": 3,
    "name": "Manga Extractor",
    "short_name": "MEext",
    "version": "3.0.0",
    "description": "Various tools for extracting manga from various site / reader.",
    "icons": {
        "16": "icons/tsumugi16.png",
        "48": "icons/tsumugi48.png",
        "128": "icons/tsumugi128.png"
    },
    "action": {
        "default_title": "Manga Extractor"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://comic-walker.com/*",
                "*://*.comic-walker.com/*",
                "*://www.pixiv.net/artworks/*",
                "*://*.nicovideo.jp/*",
                "*://read.amazon.com/*",
                "*://*.amazon.com/*/reader/*",
                "*://comicbushi.com/*",
                "*://*.comicbushi.com/*"
            ],
            "js": ["content-script.js"],
            "css": ["content-overlay.css"],
            "run_at": "document_end"
        }
    ],
    "permissions": ["activeTab", "scripting", "tabs", "storage"],
    "web_accessible_resources": [
        {
            "resources": [
                "overlay.html",
                "overlay.js",
                "content-script.js",
                "content-script.js.map",
                "handlers/nico-douga.js",
                "handlers/nico-douga.js.map",
                "handlers/speed-binb-reader.js",
                "handlers/speed-binb-reader.js.map",
                "handlers/comic-walker.js",
                "handlers/comic-walker.js.map",
                "handlers/comic-pixiv.js",
                "handlers/comic-pixiv.js.map",
                "handlers/kindle.js",
                "handlers/kindle.js.map",
                "handlers/comicbushi.js",
                "handlers/comicbushi.js.map"
            ],
            "matches": ["<all_urls>"]
        }
    ]
}
