{
  "name": "meextension",
  "version": "2.0.0",
  "description": "Modern manga extractor Chrome extension built with React 18 and Bun",
  "type": "module",
  "scripts": {
    "dev": "bun run build:watch",
    "build": "bun run build:clean && bun run build:extension",
    "build:clean": "bun run --if-present rm -rf build",
    "build:extension": "bun build.ts",
    "build:watch": "bun build.ts --watch",
    "test": "bun test",
    "type-check": "tsc --noEmit",
    "lint": "bun run eslint src --ext .ts,.tsx,.js,.jsx",
    "format": "bun run prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "preview": "bun run build && cd build && python -m http.server 8080"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@extend-chrome/messages": "^1.2.2",
    "axios": "^1.7.0",
    "dom-to-image": "^2.6.0",
    "file-saver": "^2.0.5",
    "iter-tools": "^7.5.4",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "tailwindcss": "3.4.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.277",
    "@types/dom-to-image": "^2.6.7",
    "@types/file-saver": "^2.0.7",
    "@types/lodash-es": "^4.17.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "autoprefixer": "^10.4.20",
    "bun-types": "^1.2.15",
    "eslint": "^9.15.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
